# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in a local .env file or your deployment secret store.
GEMINI_API_KEY="your-gemini-api-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APP_ENV: Used to namespace shared room state and persistence per environment.
APP_ENV="development"

# DEFAULT_ROOM_ID: Shared room identifier for the live session state.
DEFAULT_ROOM_ID="main-room"

# Redis-backed shared state.
# Use REDIS_URL locally, or REDIS_HOST / REDIS_PORT in Cloud Run with Memorystore.
# REDIS_URL="redis://127.0.0.1:6379"
# REDIS_HOST="10.0.0.3"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_TLS="false"

# Firestore durability controls. Production should leave both defaults in place.
REQUIRE_REDIS="false"
REQUIRE_FIRESTORE="false"
FIRESTORE_COLLECTION="cognitive_swarm_sessions"

# ALLOW_IN_MEMORY_STATE: Keep this true for local development only.
ALLOW_IN_MEMORY_STATE="true"
